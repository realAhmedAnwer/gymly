# =============================================================================
# Gymly - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running Docker Compose.
#   cp .env.example .env
#
# All variables defined here are consumed by docker-compose.yml and injected
# as environment variables into the running containers.
# =============================================================================

# -----------------------------------------------------------------------------
# ASP.NET CORE
# -----------------------------------------------------------------------------
# Runtime environment: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# HTTP/HTTPS port mappings
ASPNETCORE_HTTP_PORTS=8080
ASPNETCORE_HTTPS_PORTS=8081

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (SQL Server 2022)
# -----------------------------------------------------------------------------
# SA (System Administrator) password — must meet SQL Server complexity policy:
#   Minimum 8 characters, including uppercase, lowercase, digits, and symbols.
MSSQL_SA_PASSWORD=YourSecurePassword123!

# Database name used by the application
GYMLY_DATABASE=GymlyDb

# Full connection string consumed by the ASP.NET Core application.
# When running inside Docker Compose, the server host is the service name
# `gymly-db`. When connecting from the host machine, use `127.0.0.1,1433`.
CONNECTION_STRING=Server=gymly-db;Database=GymlyDb;User Id=sa;Password=YourSecurePassword123!;TrustServerCertificate=True;MultipleActiveResultSets=true

# -----------------------------------------------------------------------------
# SEED DATA — Super Admin Credentials
# -----------------------------------------------------------------------------
# These values are read by DatabaseSeeder on first startup to create the
# initial Super Admin user. They map to the SuperAdminSettings configuration
# section in appsettings.Development.json.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=superadmin@gymly.com
SUPER_ADMIN_FULL_NAME=Super Administrator
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# -----------------------------------------------------------------------------
# REDIS CACHE (Redis 8)
# -----------------------------------------------------------------------------
# Redis connection string for distributed caching.
# When running inside Docker Compose, the server host is the service name
# `gymly-redis`. When connecting from the host machine, use `127.0.0.1:6379`.
REDIS_CONNECTION_STRING=gymly-redis:6379

# -----------------------------------------------------------------------------
# DOCKER BUILD
# -----------------------------------------------------------------------------
# Build configuration: Debug | Release
BUILD_CONFIGURATION=Release
