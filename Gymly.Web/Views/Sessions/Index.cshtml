@model Gymly.Web.Models.Sessions.SessionsDashboardViewModel

@{
    ViewData["Title"] = "Sessions";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Sessions</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total sessions</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Schedule Session</a>
</div>

<div class="gymly-card mb-6">
    <form asp-action="Index" method="get" class="flex flex-wrap items-end gap-4">
        <div class="flex-1 min-w-[200px]">
            <label class="gymly-label">Search</label>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Class or trainer name..." class="gymly-input" />
        </div>
        <div class="min-w-[160px]">
            <label class="gymly-label">Sort by</label>
            <select name="sortBy" class="gymly-select">
                <option value="" selected="@(Model.SortBy == null)">Start time (newest)</option>
                <option value="starttime" selected="@(Model.SortBy == "starttime")">Start time (oldest)</option>
                <option value="classname" selected="@(Model.SortBy == "classname")">Class (A-Z)</option>
                <option value="classname_desc" selected="@(Model.SortBy == "classname_desc")">Class (Z-A)</option>
                <option value="trainername" selected="@(Model.SortBy == "trainername")">Trainer (A-Z)</option>
                <option value="trainername_desc" selected="@(Model.SortBy == "trainername_desc")">Trainer (Z-A)</option>
            </select>
        </div>
        <div class="min-w-[160px]">
            <label class="gymly-label">Date from</label>
            <input type="date" name="dateFrom" value="@(Model.DateFrom?.ToString("yyyy-MM-dd"))" class="gymly-input" />
        </div>
        <div class="min-w-[160px]">
            <label class="gymly-label">Date to</label>
            <input type="date" name="dateTo" value="@(Model.DateTo?.ToString("yyyy-MM-dd"))" class="gymly-input" />
        </div>
        <button type="submit" class="gymly-btn gymly-btn-primary">Apply</button>
    </form>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Sessions.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No sessions match the current filter.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Class</th>
                        <th>Trainer</th>
                        <th>Starts At</th>
                        <th>Ends At</th>
                        <th>Capacity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.Sessions)
                    {
                        <tr>
                            <td class="text-gray-400">@session.Id</td>
                            <td class="font-medium">@session.ClassName</td>
                            <td>@session.TrainerName</td>
                            <td>@session.StartTime</td>
                            <td>@session.EndTime</td>
                            <td>
                                @if (session.MaxCapacity > 0)
                                {
                                    var fillPercent = session.MaxCapacity > 0 ? (session.BookedCount * 100 / session.MaxCapacity) : 0;
                                    if (fillPercent >= 100)
                                    {
                                        <span class="capacity-red">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                    else if (fillPercent >= 80)
                                    {
                                        <span class="capacity-orange">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                    else
                                    {
                                        <span class="capacity-green">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-gray-500">@session.BookedCount / Unlimited</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        <span class="text-sm text-gray-500 mr-2">Page @Model.CurrentPage of @Model.TotalPages</span>
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-sortBy="@Model.SortBy" asp-route-searchTerm="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="gymly-page-btn">&laquo; Prev</a>
        }
        @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
        {
            <a asp-action="Index" asp-route-page="@i" asp-route-sortBy="@Model.SortBy" asp-route-searchTerm="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="gymly-page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-sortBy="@Model.SortBy" asp-route-searchTerm="@Model.SearchTerm" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" class="gymly-page-btn">Next &raquo;</a>
        }
    </div>
}