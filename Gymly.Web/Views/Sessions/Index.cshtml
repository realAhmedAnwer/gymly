@model Gymly.Web.Models.Sessions.SessionsDashboardViewModel

@{
    ViewData["Title"] = "Sessions";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Sessions</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total sessions</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Schedule Session</a>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Sessions.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No sessions scheduled.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Class</th>
                        <th>Trainer</th>
                        <th>Starts At</th>
                        <th>Ends At</th>
                        <th>Capacity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.Sessions)
                    {
                        <tr>
                            <td class="text-gray-400">@session.Id</td>
                            <td class="font-medium">@session.ClassName</td>
                            <td>@session.TrainerName</td>
                            <td>@session.StartTime</td>
                            <td>@session.EndTime</td>
                            <td>
                                @if (session.MaxCapacity > 0)
                                {
                                    var fillPercent = session.MaxCapacity > 0 ? (session.BookedCount * 100 / session.MaxCapacity) : 0;
                                    if (fillPercent >= 100)
                                    {
                                        <span class="capacity-red">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                    else if (fillPercent >= 80)
                                    {
                                        <span class="capacity-orange">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                    else
                                    {
                                        <span class="capacity-green">@session.BookedCount / @session.MaxCapacity</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-gray-500">@session.BookedCount / Unlimited</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="Index" asp-route-page="@i" class="gymly-page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}