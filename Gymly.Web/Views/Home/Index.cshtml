@{
    ViewData["Title"] = "Dashboard";
    var upcomingSessions = ViewBag.UpcomingSessions as List<Gymly.Application.Features.Home.Queries.GetDashboardStats.UpcomingSessionDto>;
}

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="stat-card">
        <div class="stat-card-value text-gymly-primary">@ViewBag.TotalMembers</div>
        <div class="stat-card-label">Total Members</div>
        <div class="stat-card-sub">@ViewBag.ActiveMembers active / @ViewBag.InactiveMembers inactive</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-gymly-success">@ViewBag.ActiveMemberships</div>
        <div class="stat-card-label">Active Memberships</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-gymly-accent">@ViewBag.TrainersCount</div>
        <div class="stat-card-label">Trainers</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-purple-500">@ViewBag.ClassesCount</div>
        <div class="stat-card-label">Classes</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-cyan-500">@ViewBag.ActivePlans</div>
        <div class="stat-card-label">Active Plans</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-rose-500">@ViewBag.TodaySessions</div>
        <div class="stat-card-label">Today's Sessions</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-indigo-500">@ViewBag.TodayCheckIns</div>
        <div class="stat-card-label">Check-Ins Today</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value text-amber-500">@ViewBag.TotalBookingsToday</div>
        <div class="stat-card-label">Bookings Today</div>
    </div>
</div>

<div class="gymly-card">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900">Upcoming Sessions</h2>
        <a asp-controller="Sessions" asp-action="Index" class="text-sm text-gymly-primary hover:text-gymly-primary-dark font-medium">View All &rarr;</a>
    </div>

    @if (upcomingSessions != null && upcomingSessions.Any())
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>Class</th>
                        <th>Trainer</th>
                        <th>Start</th>
                        <th>End</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in upcomingSessions)
                    {
                        <tr>
                            <td class="font-medium">@session.ClassName</td>
                            <td>@session.TrainerName</td>
                            <td>@session.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@session.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-gray-400 text-sm py-4 text-center">No upcoming sessions scheduled.</p>
    }
</div>

<div class="flex flex-wrap gap-3 mt-6">
    <a asp-controller="Members" asp-action="Index" class="gymly-btn gymly-btn-secondary">Manage Members</a>
    <a asp-controller="Sessions" asp-action="Index" class="gymly-btn gymly-btn-secondary">View All Sessions</a>
    <a asp-controller="Attendance" asp-action="Index" class="gymly-btn gymly-btn-secondary">Check-In</a>
</div>