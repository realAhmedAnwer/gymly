@model Gymly.Web.Models.Bookings.CreateBookingViewModel

@{
    ViewData["Title"] = "Create Booking";
}

<h2>Create New Booking</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" style="color:red;"></div>

    <p>
        <label>Session:</label><br />
        <select asp-for="SessionId">
            <option value="">-- Select Session --</option>
            @foreach (var session in Model.AvailableSessions)
            {
                <option value="@session.Id" disabled="@session.IsFull">
                    @session.Display
                    @(session.MaxCapacity > 0 ? ("(" + session.BookedCount + "/" + session.MaxCapacity + (session.IsFull ? " - FULL)" : ")")) : "")
                </option>
            }
        </select>
        @if (Model.AvailableSessions.Any(s => s.IsFull))
        {
            <br /><span style="color: #888; font-size: 0.85em;">Full sessions are disabled.</span>
        }
    </p>

    <p>
        <label>Member:</label><br />
        <div style="position: relative; width: 300px;">
            <input type="text" id="memberSearch" placeholder="Search member name..." autocomplete="off" style="width: 100%;" />
            <div id="searchResults" style="position: absolute; top: 100%; left: 0; width: 100%; background: white; border: 1px solid #ccc; z-index: 1000; display: none; max-height: 200px; overflow-y: auto;"></div>
            <input type="hidden" asp-for="MemberId" id="selectedMemberId" />
            <div id="selectedMemberName" style="margin-top: 5px; font-weight: bold; color: #333;"></div>
        </div>
    </p>

    <p>
        <button type="submit">Book</button>
        <a asp-action="Index">Cancel</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const searchInput = document.getElementById('memberSearch');
        const resultsDiv = document.getElementById('searchResults');
        const memberIdInput = document.getElementById('selectedMemberId');
        const memberNameDiv = document.getElementById('selectedMemberName');
        let abortController = null;

        searchInput.addEventListener('input', async () => {
            const query = searchInput.value.trim();
            if (query.length < 2) {
                resultsDiv.style.display = 'none';
                return;
            }

            if (abortController) abortController.abort();
            abortController = new AbortController();

            try {
                const response = await fetch(`/Members/Search?query=${encodeURIComponent(query)}`, { signal: abortController.signal });
                const members = await response.json();

                resultsDiv.innerHTML = '';
                if (members.length === 0) {
                    resultsDiv.innerHTML = '<div style="padding: 5px; color: #888;">No members found</div>';
                } else {
                    members.forEach(m => {
                        const div = document.createElement('div');
                        div.style.padding = '5px';
                        div.style.cursor = 'pointer';
                        div.style.borderBottom = '1px solid #eee';
                        div.textContent = m.name;
                        div.addEventListener('click', () => {
                            memberIdInput.value = m.id;
                            memberNameDiv.textContent = `Selected: ${m.name}`;
                            searchInput.value = m.name;
                            resultsDiv.style.display = 'none';
                        });
                        div.addEventListener('mouseover', () => div.style.backgroundColor = '#f0f0f0');
                        div.addEventListener('mouseout', () => div.style.backgroundColor = 'white');
                        resultsDiv.appendChild(div);
                    });
                }
                resultsDiv.style.display = 'block';
            } catch (e) {
                if (e.name !== 'AbortError') console.error('Search error:', e);
            }
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !resultsDiv.contains(e.target)) {
                resultsDiv.style.display = 'none';
            }
        });
    </script>
}
