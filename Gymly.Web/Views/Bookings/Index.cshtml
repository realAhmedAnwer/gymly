@model Gymly.Web.Models.Bookings.BookingsIndexViewModel

@{
    ViewData["Title"] = "Bookings";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Bookings</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total bookings</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Create Booking</a>
</div>

<div class="gymly-card mb-6">
    <form asp-action="Index" method="get" class="flex flex-wrap items-end gap-4">
        <div class="flex items-center gap-2 pb-1">
            <input type="checkbox" name="showCancelled" value="true" checked="@Model.ShowCancelled" class="gymly-checkbox" id="showCancelled" />
            <label for="showCancelled" class="text-sm text-gray-600">Show cancelled bookings</label>
        </div>
        <button type="submit" class="gymly-btn gymly-btn-primary">Apply</button>
    </form>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Bookings.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No bookings match the current filter.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Trainer</th>
                        <th>Member</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Booked At</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr>
                            <td class="font-medium">@booking.ClassName</td>
                            <td>@booking.TrainerName</td>
                            <td>@booking.MemberName</td>
                            <td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@booking.EndTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-gray-500">@booking.BookedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (booking.IsCancelled)
                                {
                                    <span class="gymly-badge gymly-badge-danger">Cancelled</span>
                                }
                                else
                                {
                                    <span class="gymly-badge gymly-badge-success">Active</span>
                                }
                            </td>
                            <td>
                                @if (!booking.IsCancelled)
                                {
                                    <form asp-action="Cancel" asp-route-id="@booking.Id" method="post" onsubmit="return confirm('Cancel this booking?');">
                                        <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        <span class="text-sm text-gray-500 mr-2">Page @Model.CurrentPage of @Model.TotalPages</span>
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-sessionId="@Model.FilterSessionId" asp-route-memberId="@Model.FilterMemberId" asp-route-showCancelled="@Model.ShowCancelled" class="gymly-page-btn">&laquo; Prev</a>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-sessionId="@Model.FilterSessionId" asp-route-memberId="@Model.FilterMemberId" asp-route-showCancelled="@Model.ShowCancelled" class="gymly-page-btn">Next &raquo;</a>
        }
    </div>
}