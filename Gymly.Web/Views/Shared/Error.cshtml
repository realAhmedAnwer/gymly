@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center">
        <h1 class="text-6xl font-extrabold text-gymly-danger mb-4">Error</h1>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Something went wrong</h2>
        <p class="text-gray-500 mb-4">An error occurred while processing your request.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-sm text-gray-400 mb-6">
                Request ID: <code class="font-mono bg-gray-100 px-2 py-1 rounded">@Model.RequestId</code>
            </p>
        }
        <a asp-controller="Home" asp-action="Index" class="gymly-btn gymly-btn-primary">Return to Dashboard</a>
    </div>
</div>