@model Gymly.Web.Models.Users.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="max-w-xl">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Create User</h2>
        <a asp-action="Index" class="gymly-btn gymly-btn-secondary gymly-btn-sm">Back to List</a>
    </div>

    <div class="gymly-card">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>

            <div class="mb-4">
                <label asp-for="Username" class="gymly-label">Username</label>
                <input asp-for="Username" class="gymly-input" placeholder="Enter username" />
                <span asp-validation-for="Username" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="FullName" class="gymly-label">Full Name</label>
                <input asp-for="FullName" class="gymly-input" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Email" class="gymly-label">Email</label>
                <input asp-for="Email" class="gymly-input" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="gymly-label">Password</label>
                <input asp-for="Password" class="gymly-input" placeholder="Enter password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div class="mb-6">
                <label asp-for="SystemRoleId" class="gymly-label">Role</label>
                <select asp-for="SystemRoleId" class="gymly-select">
                    <option value="">-- Select Role --</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
                <span asp-validation-for="SystemRoleId" class="field-validation-error"></span>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="gymly-btn gymly-btn-primary">Create User</button>
                <a asp-action="Index" class="gymly-btn gymly-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}