@model Gymly.Web.Models.Users.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="max-w-xl">
    <div class="mb-6">
        <h2 class="text-xl font-bold text-gray-900">My Profile</h2>
    </div>

    <div class="gymly-card">
        <form asp-action="Profile" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>

            <div class="mb-4">
                <label class="gymly-label">Username</label>
                <input value="@Model.Username" disabled class="gymly-input bg-gray-50 cursor-not-allowed" />
            </div>

            <div class="mb-4">
                <label class="gymly-label">Role</label>
                <input value="@Model.RoleName" disabled class="gymly-input bg-gray-50 cursor-not-allowed" />
            </div>

            <div class="mb-4">
                <label class="gymly-label">Status</label>
                <div class="py-2">
                    @if (Model.IsActive)
                    {
                        <span class="gymly-badge gymly-badge-success">Active</span>
                    }
                    else
                    {
                        <span class="gymly-badge gymly-badge-danger">Inactive</span>
                    }
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="FullName" class="gymly-label">Full Name</label>
                <input asp-for="FullName" class="gymly-input" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="mb-6">
                <label asp-for="Email" class="gymly-label">Email</label>
                <input asp-for="Email" class="gymly-input" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="gymly-btn gymly-btn-primary">Update Profile</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}