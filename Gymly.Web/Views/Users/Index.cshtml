@model Gymly.Web.Models.Users.UsersIndexViewModel

@{
    ViewData["Title"] = "Users";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">System Users</h2>
        <p class="text-sm text-gray-500">@Model.Users.Count total users</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Add User</a>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Users.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No users found.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        var isProtectedUser = user.Role == "Super Admin" || user.Role == "Admin";
                        var canDelete = User.IsInRole("Super Admin") || (!isProtectedUser && User.IsInRole("Admin"));

                        <tr>
                            <td class="font-medium">@user.Username</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td><span class="gymly-badge gymly-badge-info">@user.Role</span></td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="gymly-badge gymly-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="gymly-badge gymly-badge-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (canDelete)
                                {
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm" onclick="return confirm('Are you sure you want to delete @user.Username?');">Delete</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>