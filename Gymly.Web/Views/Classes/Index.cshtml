@model Gymly.Web.Models.Classes.ClassesIndexViewModel

@{
    ViewData["Title"] = "Classes";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Classes</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total classes</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Add Class</a>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Classes.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No classes registered in the system.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fitnessClass in Model.Classes)
                    {
                        <tr>
                            <td class="text-gray-400">@fitnessClass.Id</td>
                            <td class="font-medium">@fitnessClass.Name</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@fitnessClass.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this class?');">
                                    <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="Index" asp-route-page="@i" class="gymly-page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}