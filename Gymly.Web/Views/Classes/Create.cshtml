@model Gymly.Web.Models.Classes.CreateClassViewModel

@{
    ViewData["Title"] = "Create Class";
}

<h2>Create New Fitness Class Definition</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" style="color:red;"></div>

    <p>
        <label asp-for="Name">Class Title / Name:</label><br />
        <input asp-for="Name" />
        <span asp-validation-for="Name" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="Description">Description:</label><br />
        <textarea asp-for="Description" rows="3" cols="40"></textarea>
        <span asp-validation-for="Description" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="MaxCapacity">Maximum Capacity Attendance Limit:</label><br />
        <input asp-for="MaxCapacity" type="number" />
        <span asp-validation-for="MaxCapacity" style="color:red;"></span>
    </p>

    <p>
        <button type="submit">Save Class Definition</button>
        <a asp-action="Index">Cancel</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}