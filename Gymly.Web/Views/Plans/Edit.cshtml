@model Gymly.Web.Models.Plans.EditPlanViewModel
@using Gymly.Domain.Enums

@{
    ViewData["Title"] = "Edit Plan";
}

<h2>Edit Membership Plan</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" style="color:red;"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="IsActive" />

    <p>
        <label asp-for="Title">Plan Title:</label><br />
        <input asp-for="Title" />
        <span asp-validation-for="Title" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="Description">Description:</label><br />
        <textarea asp-for="Description" rows="3" cols="40"></textarea>
        <span asp-validation-for="Description" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="Price">Price:</label><br />
        <input asp-for="Price" type="number" step="0.01" />
        <span asp-validation-for="Price" style="color:red;"></span>
    </p>

    <p>
        <label asp-for="DurationInDays">Duration (Days):</label><br />
        <input asp-for="DurationInDays" type="number" />
        <span asp-validation-for="DurationInDays" style="color:red;"></span>
    </p>

    <p>
        <button type="submit">Save Changes</button>
        <a asp-action="Index">Cancel</a>
        <a asp-action="Details" asp-route-id="@Model.Id">View Details</a>
    </p>
</form>

<h3>Access Rules</h3>

@if (Model.AccessRules.Any())
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>ID</th>
                <th>Rule Type</th>
                <th>Rule Value</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rule in Model.AccessRules)
            {
                <tr>
                    <td>@rule.Id</td>
                    <td>@rule.RuleType</td>
                    <td>@rule.RuleValue</td>
                    <td>
                        <form asp-action="RemoveRule" method="post" style="display:inline;">
                            <input type="hidden" name="ruleId" value="@rule.Id" />
                            <input type="hidden" name="planId" value="@Model.Id" />
                            <button type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No access rules defined yet.</p>
}

<h4>Add New Access Rule</h4>
<form asp-action="AddRule" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <p>
        <label>Rule Type:</label><br />
        <select name="NewRuleType">
            @foreach (var ruleType in Enum.GetValues<AccessType>())
            {
                <option value="@ruleType">@ruleType</option>
            }
        </select>
    </p>
    <p>
        <label>Rule Value:</label><br />
        <input name="NewRuleValue" placeholder="e.g., 1, 2, 3" />
    </p>
    <p>
        <button type="submit">Add Rule</button>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}