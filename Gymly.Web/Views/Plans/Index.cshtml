@model Gymly.Web.Models.Plans.PlansIndexViewModel

@{
    ViewData["Title"] = "Plans";
    var sortBy = ViewBag.SortBy as string ?? "title";
    var showInactive = ViewBag.ShowInactive as bool? ?? false;
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Membership Plans</h2>
        <p class="text-sm text-gray-500">@Model.TotalPlans total plans</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Add Plan</a>
</div>

<div class="gymly-card mb-6">
    <form asp-action="Index" method="get" class="flex flex-wrap items-end gap-4">
        <div class="min-w-[160px]">
            <label class="gymly-label">Sort by</label>
            <select name="sortBy" class="gymly-select">
                <option value="title" selected="@(sortBy == "title")">Title</option>
                <option value="price" selected="@(sortBy == "price")">Price (low to high)</option>
                <option value="price_desc" selected="@(sortBy == "price_desc")">Price (high to low)</option>
                <option value="duration" selected="@(sortBy == "duration")">Duration (short to long)</option>
                <option value="duration_desc" selected="@(sortBy == "duration_desc")">Duration (long to short)</option>
            </select>
        </div>
        <div class="flex items-center gap-2 pb-1">
            <input type="checkbox" name="showInactive" value="true" checked="@showInactive" class="gymly-checkbox" id="showInactive" />
            <label for="showInactive" class="text-sm text-gray-600">Show inactive</label>
        </div>
        <button type="submit" class="gymly-btn gymly-btn-primary">Apply</button>
    </form>
</div>

@if (!Model.Plans.Any())
{
    <p class="text-gray-400 text-sm py-8 text-center">No membership plans match the current filter.</p>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @foreach (var plan in Model.Plans)
        {
            <div class="gymly-card">
                <div class="flex items-start justify-between mb-3">
                    <div>
                        <h3 class="font-bold text-gray-900">@plan.Title</h3>
                        <p class="text-xs text-gray-400">ID: @plan.Id</p>
                    </div>
                    @if (plan.IsActive)
                    {
                        <span class="gymly-badge gymly-badge-success">Active</span>
                    }
                    else
                    {
                        <span class="gymly-badge gymly-badge-danger">Inactive</span>
                    }
                </div>

                <div class="flex items-center gap-4 mb-3 text-sm">
                    <span class="text-gray-600"><strong class="text-gray-900">@plan.Price.ToString("C")</strong></span>
                    <span class="text-gray-600"><strong class="text-gray-900">@plan.DurationInDays</strong> days</span>
                </div>

                <div class="flex items-center gap-2 mb-3">
                    <a asp-action="Details" asp-route-id="@plan.Id" class="gymly-btn gymly-btn-ghost gymly-btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@plan.Id" class="gymly-btn gymly-btn-ghost gymly-btn-sm">Edit</a>
                    @if (plan.IsActive)
                    {
                        <form asp-action="Delete" asp-route-id="@plan.Id" method="post" onsubmit="return confirm('Deactivate this plan?');">
                            <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm">Deactivate</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Activate" asp-route-id="@plan.Id" method="post">
                            <button type="submit" class="gymly-btn gymly-btn-success gymly-btn-sm">Activate</button>
                        </form>
                    }
                </div>

                @if (plan.AccessRules.Any())
                {
                    <div class="border-t border-gray-100 pt-3">
                        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Access Rules</h4>
                        <div class="overflow-x-auto">
                            <table class="gymly-table text-xs">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in plan.AccessRules)
                                    {
                                        <tr>
                                            <td>@rule.RuleType</td>
                                            <td>@rule.RuleValue</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}