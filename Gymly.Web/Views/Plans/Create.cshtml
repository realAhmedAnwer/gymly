@model Gymly.Web.Models.Plans.CreatePlanViewModel

@{
    ViewData["Title"] = "Create Plan";
}

<div class="max-w-xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Create New Plan</h2>
        <a asp-action="Index" class="gymly-btn gymly-btn-secondary gymly-btn-sm">Back to List</a>
    </div>

    <div class="gymly-card">
        <form asp-action="Create" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>
            }

            <div class="mb-4">
                <label asp-for="Title" class="gymly-label">Plan Title</label>
                <input asp-for="Title" class="gymly-input" placeholder="Enter plan title" />
                <span asp-validation-for="Title" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="gymly-label">Description</label>
                <textarea asp-for="Description" class="gymly-textarea" rows="3" placeholder="Enter plan description"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                    <label asp-for="Price" class="gymly-label">Price</label>
                    <input asp-for="Price" type="number" step="0.01" class="gymly-input" placeholder="0.00" />
                    <span asp-validation-for="Price" class="field-validation-error"></span>
                </div>
                <div>
                    <label asp-for="DurationInDays" class="gymly-label">Duration (Days)</label>
                    <input asp-for="DurationInDays" type="number" class="gymly-input" placeholder="30" />
                    <span asp-validation-for="DurationInDays" class="field-validation-error"></span>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="gymly-btn gymly-btn-primary">Save Plan</button>
                <a asp-action="Index" class="gymly-btn gymly-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}