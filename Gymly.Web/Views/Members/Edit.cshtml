@model Gymly.Web.Models.Members.EditMemberViewModel

@{
    ViewData["Title"] = "Edit Member";
    var token = ViewBag.AttendanceCardToken as Guid?;
}

<div class="max-w-xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Edit Member</h2>
        <a asp-action="Index" class="gymly-btn gymly-btn-secondary gymly-btn-sm">Back to List</a>
    </div>

    <div class="gymly-card">
        <form asp-action="Edit" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>
            }
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IsActive" />
            <input type="hidden" asp-for="RegistrationDate" />

            <div class="mb-4">
                <label asp-for="Name" class="gymly-label">Full Name</label>
                <input asp-for="Name" class="gymly-input" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Email" class="gymly-label">Email</label>
                <input asp-for="Email" type="email" class="gymly-input" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Phone" class="gymly-label">Phone</label>
                <input asp-for="Phone" type="tel" class="gymly-input" />
                <span asp-validation-for="Phone" class="field-validation-error"></span>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="gymly-label">Status</label>
                    <div class="py-2">
                        @if (Model.IsActive)
                        {
                            <span class="gymly-badge gymly-badge-success">Active</span>
                        }
                        else
                        {
                            <span class="gymly-badge gymly-badge-danger">Inactive</span>
                        }
                    </div>
                </div>
                <div>
                    <label class="gymly-label">Registered</label>
                    <div class="py-2 text-sm text-gray-600">@Model.RegistrationDate.ToString("yyyy-MM-dd")</div>
                </div>
            </div>

            @if (token.HasValue)
            {
                <div class="mb-4 p-3 bg-gray-50 rounded-lg border border-gray-200">
                    <label class="gymly-label mb-1">Attendance Card Token</label>
                    <code class="text-sm text-gymly-primary font-mono">@token.Value</code>
                </div>
            }

            <div class="flex items-center gap-3">
                <button type="submit" class="gymly-btn gymly-btn-primary">Save Changes</button>
                <a asp-action="Index" class="gymly-btn gymly-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}