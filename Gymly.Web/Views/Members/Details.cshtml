@model Gymly.Application.Features.Members.Queries.GetMembers.MemberDto

@{
    ViewData["Title"] = "Member Details";
    var membership = ViewBag.Membership as Gymly.Application.Features.Members.Queries.GetMemberMembership.MemberMembershipDto;
    var attendanceLogs = ViewBag.AttendanceLogs as List<Gymly.Application.Features.Members.Queries.GetMemberAttendanceLogs.AttendanceLogDto>;
    var qrBase64 = ViewBag.QRCodeBase64 as string;
}

<div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold text-gray-900">Member Details</h2>
    <div class="flex items-center gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="gymly-btn gymly-btn-secondary gymly-btn-sm">Edit</a>
        <a asp-controller="Memberships" asp-action="Create" asp-route-memberId="@Model.Id" class="gymly-btn gymly-btn-primary gymly-btn-sm">Assign Plan</a>
        <a asp-action="Index" class="gymly-btn gymly-btn-ghost gymly-btn-sm">Back to List</a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 gymly-card">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Personal Information</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="gymly-label">ID</label>
                <p class="text-sm text-gray-600">@Model.Id</p>
            </div>
            <div>
                <label class="gymly-label">Name</label>
                <p class="text-sm font-medium text-gray-900">@Model.Name</p>
            </div>
            <div>
                <label class="gymly-label">Email</label>
                <p class="text-sm text-gray-600">@Model.Email</p>
            </div>
            <div>
                <label class="gymly-label">Phone</label>
                <p class="text-sm text-gray-600">@(string.IsNullOrEmpty(Model.Phone) ? "-" : Model.Phone)</p>
            </div>
            <div>
                <label class="gymly-label">Registration Date</label>
                <p class="text-sm text-gray-600">@Model.RegistrationDate.ToString("yyyy-MM-dd")</p>
            </div>
            <div>
                <label class="gymly-label">Status</label>
                <div>
                    @if (Model.IsActive)
                    {
                        <span class="gymly-badge gymly-badge-success">Active</span>
                    }
                    else
                    {
                        <span class="gymly-badge gymly-badge-danger">Inactive</span>
                    }
                </div>
            </div>
            <div class="sm:col-span-2">
                <label class="gymly-label">Attendance Card Token</label>
                <code class="text-xs text-gymly-primary font-mono bg-purple-50 px-2 py-1 rounded">@Model.AttendanceCardToken</code>
            </div>
        </div>
    </div>

    <div class="gymly-card flex flex-col items-center justify-center">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">QR Code</h3>
        @if (!string.IsNullOrEmpty(qrBase64))
        {
            <img src="data:image/png;base64,@qrBase64" alt="Member QR Code" class="w-40 h-40 rounded-lg" />
        }
        else
        {
            <div class="w-40 h-40 bg-gray-100 rounded-lg flex items-center justify-center text-gray-400 text-sm">No QR</div>
        }
    </div>
</div>

<div class="gymly-card mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Current Membership</h3>
    @if (membership != null)
    {
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
            <div>
                <label class="gymly-label">Plan</label>
                <p class="text-sm font-medium text-gray-900">@membership.PlanTitle</p>
            </div>
            <div>
                <label class="gymly-label">Price</label>
                <p class="text-sm text-gray-600">@membership.PlanPrice.ToString("C")</p>
            </div>
            <div>
                <label class="gymly-label">Duration</label>
                <p class="text-sm text-gray-600">@membership.PlanDurationDays days</p>
            </div>
            <div>
                <label class="gymly-label">Start Date</label>
                <p class="text-sm text-gray-600">@membership.StartDate.ToString("yyyy-MM-dd")</p>
            </div>
            <div>
                <label class="gymly-label">End Date</label>
                <p class="text-sm text-gray-600">@membership.EndDate.ToString("yyyy-MM-dd")</p>
            </div>
            <div>
                <label class="gymly-label">Status</label>
                <div>
                    @membership.Status
                    @if (membership.IsCurrentlyValid)
                    {
                        <span class="gymly-badge gymly-badge-success ml-1">Valid</span>
                    }
                    else
                    {
                        <span class="gymly-badge gymly-badge-danger ml-1">Expired</span>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <p class="text-gray-400 text-sm py-2">No membership record found.</p>
    }
</div>

<div class="gymly-card mt-6">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Recent Check-in History</h3>
    @if (attendanceLogs != null && attendanceLogs.Any())
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>Method</th>
                        <th>Result</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in attendanceLogs)
                    {
                        <tr>
                            <td>@log.ScannedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@log.Method</td>
                            <td>
                                @if (log.WasGranted)
                                {
                                    <span class="gymly-badge gymly-badge-success">Granted</span>
                                }
                                else
                                {
                                    <span class="gymly-badge gymly-badge-danger">Denied</span>
                                }
                            </td>
                            <td class="text-gray-500">@(string.IsNullOrEmpty(log.RejectionReason) ? "-" : log.RejectionReason)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-gray-400 text-sm py-2">No check-in history found.</p>
    }
</div>