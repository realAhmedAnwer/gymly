@model Gymly.Web.Models.Members.MembersIndexViewModel

@{
    ViewData["Title"] = "Members";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Members</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total members</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Add Member</a>
</div>

<div class="gymly-card mb-6">
    <form asp-action="Index" method="get" class="flex flex-wrap items-end gap-4">
        <div class="flex-1 min-w-[200px]">
            <label class="gymly-label">Search</label>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Name or email..." class="gymly-input" />
        </div>
        <div class="min-w-[160px]">
            <label class="gymly-label">Sort by</label>
            <select name="sortBy" class="gymly-select">
                <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                <option value="email" selected="@(Model.SortBy == "email")">Email</option>
                <option value="email_desc" selected="@(Model.SortBy == "email_desc")">Email (Z-A)</option>
                <option value="registrationdate" selected="@(Model.SortBy == "registrationdate")">Registration (oldest)</option>
                <option value="registrationdate_desc" selected="@(Model.SortBy == "registrationdate_desc")">Registration (newest)</option>
            </select>
        </div>
        <div class="flex items-center gap-2 pb-1">
            <input type="checkbox" name="showInactive" value="true" checked="@Model.ShowInactive" class="gymly-checkbox" id="showInactive" />
            <label for="showInactive" class="text-sm text-gray-600">Show inactive</label>
        </div>
        <button type="submit" class="gymly-btn gymly-btn-primary">Apply</button>
    </form>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Members.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No members match the current filter.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Registered</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model.Members)
                    {
                        <tr>
                            <td class="text-gray-400">@member.Id</td>
                            <td class="font-medium">@member.Name</td>
                            <td>@member.Email</td>
                            <td>@member.Phone</td>
                            <td>@member.RegistrationDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (member.IsActive)
                                {
                                    <span class="gymly-badge gymly-badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="gymly-badge gymly-badge-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <a asp-action="Details" asp-route-id="@member.Id" class="gymly-btn gymly-btn-ghost gymly-btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@member.Id" class="gymly-btn gymly-btn-ghost gymly-btn-sm">Edit</a>
                                    @if (member.IsActive)
                                    {
                                        <form asp-action="Deactivate" asp-route-id="@member.Id" method="post" onsubmit="return confirm('Deactivate this member?');">
                                            <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm">Deactivate</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Activate" asp-route-id="@member.Id" method="post">
                                            <button type="submit" class="gymly-btn gymly-btn-success gymly-btn-sm">Activate</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        <span class="text-sm text-gray-500 mr-2">Page @Model.CurrentPage of @Model.TotalPages</span>
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-sortBy="@Model.SortBy" asp-route-showInactive="@Model.ShowInactive" asp-route-searchTerm="@Model.SearchTerm" class="gymly-page-btn">&laquo; Prev</a>
        }
        @for (var i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
        {
            <a asp-action="Index" asp-route-page="@i" asp-route-sortBy="@Model.SortBy" asp-route-showInactive="@Model.ShowInactive" asp-route-searchTerm="@Model.SearchTerm" class="gymly-page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-sortBy="@Model.SortBy" asp-route-showInactive="@Model.ShowInactive" asp-route-searchTerm="@Model.SearchTerm" class="gymly-page-btn">Next &raquo;</a>
        }
    </div>
}