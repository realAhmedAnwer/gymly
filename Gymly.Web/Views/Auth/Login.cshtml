@model Gymly.Web.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<div class="min-h-[70vh] flex items-center justify-center">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4" style="background: linear-gradient(135deg, var(--gymly-primary), var(--gymly-secondary));">
                <span class="text-white text-2xl font-bold">G</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Welcome to Gymly</h1>
            <p class="text-sm text-gray-500 mt-1">Sign in to your account</p>
        </div>

        <div class="gymly-card">
            <form asp-action="Login" method="post" novalidate>
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Username" class="gymly-label">Username</label>
                    <input asp-for="Username" class="gymly-input" placeholder="Enter your username" autofocus />
                    <span asp-validation-for="Username" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="gymly-label">Password</label>
                    <input asp-for="Password" class="gymly-input" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="mb-6">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="RememberMe" class="gymly-checkbox" />
                        <span class="text-sm text-gray-600">@Html.DisplayNameFor(m => m.RememberMe)</span>
                    </label>
                </div>

                <button type="submit" class="w-full gymly-btn gymly-btn-primary py-3 text-center">Sign In</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}