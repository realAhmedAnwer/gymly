@model Gymly.Web.Models.Trainers.CreateTrainerViewModel

@{
    ViewData["Title"] = "Add Trainer";
}

<div class="max-w-xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900">Add New Trainer</h2>
        <a asp-action="Index" class="gymly-btn gymly-btn-secondary gymly-btn-sm">Back to List</a>
    </div>

    <div class="gymly-card">
        <form asp-action="Create" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="gymly-alert gymly-alert-danger mb-4"></div>
            }

            <div class="mb-4">
                <label asp-for="Name" class="gymly-label">Full Name</label>
                <input asp-for="Name" class="gymly-input" placeholder="Enter full name" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Email" class="gymly-label">Email Address</label>
                <input asp-for="Email" type="email" class="gymly-input" placeholder="Enter email address" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Phone" class="gymly-label">Phone Number</label>
                <input asp-for="Phone" class="gymly-input" placeholder="Enter phone number" />
                <span asp-validation-for="Phone" class="field-validation-error"></span>
            </div>

            <div class="mb-6">
                <label asp-for="Specialization" class="gymly-label">Specialization</label>
                <input asp-for="Specialization" class="gymly-input" placeholder="e.g., Yoga, Strength Training" />
                <span asp-validation-for="Specialization" class="field-validation-error"></span>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="gymly-btn gymly-btn-primary">Register Trainer</button>
                <a asp-action="Index" class="gymly-btn gymly-btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}