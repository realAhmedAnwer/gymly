@model Gymly.Web.Models.Trainers.TrainersIndexViewModel

@{
    ViewData["Title"] = "Trainers";
}

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
        <h2 class="text-xl font-bold text-gray-900">Trainers</h2>
        <p class="text-sm text-gray-500">@Model.TotalCount total trainers</p>
    </div>
    <a asp-action="Create" class="gymly-btn gymly-btn-primary">+ Add Trainer</a>
</div>

<div class="gymly-card overflow-hidden p-0">
    @if (!Model.Trainers.Any())
    {
        <p class="text-gray-400 text-sm py-8 text-center">No active trainers registered in the system.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="gymly-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Specialization</th>
                        <th>Hire Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trainer in Model.Trainers)
                    {
                        <tr>
                            <td class="text-gray-400">@trainer.Id</td>
                            <td class="font-medium">@trainer.Name</td>
                            <td>@trainer.Email</td>
                            <td>@trainer.Phone</td>
                            <td><span class="gymly-badge gymly-badge-info">@trainer.Specialization</span></td>
                            <td>@trainer.HireDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <form asp-action="Delete" asp-route-id="@trainer.Id" method="post" onsubmit="return confirm('Are you sure you want to remove this trainer?');">
                                    <button type="submit" class="gymly-btn gymly-btn-danger gymly-btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="gymly-pagination mt-4">
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="Index" asp-route-page="@i" class="gymly-page-btn @(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
    </div>
}