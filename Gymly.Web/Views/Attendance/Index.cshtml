@model Gymly.Web.Models.Attendance.AttendanceIndexViewModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@{
    ViewData["Title"] = "Attendance";
    var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<h2>Check-In</h2>

<h3>Scan QR Code</h3>
<form id="qrForm" asp-action="CheckInByQr" method="post" style="margin-bottom: 20px;">
    @Html.AntiForgeryToken()
    <input type="text" id="qrTokenInput" name="qrToken" placeholder="Scan or enter QR token" autofocus
           autocomplete="off" style="width: 300px; padding: 5px;" />
    <button type="submit" style="padding: 5px 15px;">Check In</button>
</form>

<h3>Manual Check-In</h3>
<form id="manualForm" asp-action="ManualCheckIn" method="post" style="margin-bottom: 20px;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="selectedMemberId" name="memberId" value="" />
    <input type="text" id="memberSearch" name="searchTerm" placeholder="Search by name, email, or phone"
           autocomplete="off" style="width: 300px; padding: 5px;" />
    <button type="submit" id="manualSubmit" disabled style="padding: 5px 15px;">Check In</button>
    <div id="selectedMemberDisplay" style="margin-top: 5px;"></div>
    <ul id="searchResults" style="list-style: none; padding: 0; margin: 5px 0 0 0; max-width: 300px;"></ul>
</form>

<script>
    window.gymlyAttendance = {
        searchUrl: '@Url.Action("SearchMembers", "Attendance")',
        antiforgeryToken: '@antiforgeryToken'
    };
</script>

<h3>Recent Check-Ins</h3>

@if (Model.RecentCheckIns.Any())
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>ID</th>
                <th>Member</th>
                <th>Date/Time</th>
                <th>Method</th>
                <th>Result</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var checkin in Model.RecentCheckIns)
            {
                <tr>
                    <td>@checkin.Id</td>
                    <td>@checkin.MemberName</td>
                    <td>@checkin.ScannedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@checkin.Method</td>
                    <td>
                        @if (checkin.WasGranted)
                        {
                            <span style="color: green;">Granted</span>
                        }
                        else
                        {
                            <span style="color: red;">Denied</span>
                        }
                    </td>
                    <td>@(string.IsNullOrEmpty(checkin.RejectionReason) ? "-" : checkin.RejectionReason)</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p><em>No check-in history found.</em></p>
}

@section Scripts {
    <script src="~/js/attendance.js" asp-append-version="true"></script>
}
